{
  "name": "@whatsapp-crm/source",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "dev": "pnpm run dev:web & pnpm run dev:api",
    "dev:web": "pnpm --filter @whatsapp-crm/web dev",
    "dev:api": "pnpm --filter @whatsapp-crm/api dev",
    "build": "pnpm run build:web && pnpm run build:api",
    "build:web": "pnpm --filter @whatsapp-crm/web build",
    "build:api": "pnpm --filter @whatsapp-crm/api build",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:rebuild": "docker-compose up --build",
    "docker:prod": "docker-compose -f docker-compose.prod.yml up --build"
  },
  "private": true,
  "dependencies": {},
  "devDependencies": {
    "@nx/js": "22.6.5",
    "@swc-node/register": "~1.11.1",
    "@swc/core": "~1.15.5",
    "@swc/helpers": "~0.5.18",
    "nx": "22.6.5",
    "prettier": "~3.6.2",
    "tslib": "^2.3.0",
    "typescript": "~5.9.2"
  }
}
